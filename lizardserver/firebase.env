# Northflank Backend Environment Variables
# Copy this to Northflank secrets/environment configuration
# Do NOT commit actual values - only add to Northflank dashboard

# Server Port (provided by Northflank, but can be overridden)
PORT=3001

# Frontend Origins for CORS
# Use the Cloudflare Pages domain(s) that will connect to this backend
# Format: https://domain1.com,https://domain2.pages.dev,http://localhost:3000
ALLOWED_ORIGINS=http://127.0.0.1:5501,https://lizardrunnerdev.pages.dev

# Firebase Configuration
# These should be created as Secrets in Northflank, NOT environment variables
# Use the Firebase Service Account JSON from Google Cloud Console
FIREBASE_PROJECT_ID=lizardrunner
FIREBASE_CLIENT_EMAIL=dunloprea@gmail.com
FIREBASE_PRIVATE_KEY=-

# Local development override
# Copy this file to .env and fill in your Firebase credentials.
# Do NOT commit .env to version control.

# Realtime Database URL
# Use your Firebase project database URL from the Console.
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Either use exact service account JSON or individual fields below.
# Option 1: full service account JSON string.
# FIREBASE_SERVICE_ACCOUNT_JSON={...}

# Option 2: individual service account fields.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Local dev server settings
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production values should remain in the deployment environment, not in this file.
